# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail example: enable 2FA, then create an App Password at
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# Address that sends the notification emails
EMAIL_FROM=you@gmail.com
# Address that receives the notification emails
EMAIL_TO=you@gmail.com

# ── Check Interval ────────────────────────────────────────────────────────────
# How often (in hours) to auto-check all active permits
# Supports decimals: 0.5 = every 30 minutes
CHECK_INTERVAL_HOURS=4

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Everett, WA eTRAKiT ───────────────────────────────────────────────────────
EVERETT_WA_USERNAME=your-portal-username
EVERETT_WA_PASSWORD=your-portal-password

# ── Bellingham, WA eTRAKiT ────────────────────────────────────────────────────
BELLINGHAM_WA_USERNAME=your-portal-username
BELLINGHAM_WA_PASSWORD=your-portal-password

# ── Shoreline, WA eTRAKiT ─────────────────────────────────────────────────────
# Public search — no credentials needed for status checks.
# To use the bulk import script, create an account at:
#   https://permits.shorelinewa.gov/etrakit/
# (requires L&I contractor license)
SHORELINE_WA_USERNAME=your-portal-username
SHORELINE_WA_PASSWORD=your-portal-password

# ── Walla Walla County, WA eTRAKiT ────────────────────────────────────────────
# Register at: https://wala-trk.aspgov.com/eTRAKiT/
WALLA_WALLA_COUNTY_WA_USERNAME=your-portal-username
WALLA_WALLA_COUNTY_WA_PASSWORD=your-portal-password

# ── Pasco, WA eTRAKiT ─────────────────────────────────────────────────────────
# Register at: https://egov-pasco.com/etrakit3/
PASCO_WA_USERNAME=your-portal-username
PASCO_WA_PASSWORD=your-portal-password

# ── Marysville, WA eTRAKiT ────────────────────────────────────────────────────
# Register at: https://permits.marysvillewa.gov/eTRAKiT/
MARYSVILLE_WA_USERNAME=your-portal-username
MARYSVILLE_WA_PASSWORD=your-portal-password

# ── Lacey, WA eTRAKiT ─────────────────────────────────────────────────────────
# Register at: https://trakitweb.ci.lacey.wa.us/eTRAKiT/
LACEY_WA_USERNAME=your-portal-username
LACEY_WA_PASSWORD=your-portal-password

# ── Accela API (global — works across all Accela cities) ─────────────────────
# Register at developer.accela.com → My Apps → create app → copy App ID + App Secret
ACCELA_APP_ID=your-accela-app-id
ACCELA_APP_SECRET=your-accela-app-secret

# Per-city Accela credentials (repeat block for each city):
# CITYNAME_ACCELA_AGENCY=agency-name-from-accela
# CITYNAME_ACCELA_USERNAME=your-citizen-portal-username
# CITYNAME_ACCELA_PASSWORD=your-citizen-portal-password

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local: postgresql://postgres:password@localhost:5432/permittracker
# Docker: docker run --name permitdb -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres
#         createdb -h localhost -U postgres permittracker
DATABASE_URL=postgresql://postgres:password@localhost:5432/permittracker

# ── Session ───────────────────────────────────────────────────────────────────
# Generate a strong random value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-random-string
